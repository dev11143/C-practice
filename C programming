// Program to add 2 numbers
#include<stdio.h>
int main()
{
    int a,b,sum;
    printf("Enter two numbers:");
    scanf("%d%d",&a,&b);
    sum=a+b;
    printf("sum=%d",sum);
    return 0;

}

